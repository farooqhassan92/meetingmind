# AI providers
# Free default: demo analysis for pasted transcripts, no hosted AI billing.
AI_PROVIDER=ollama

# Optional free local LLM via Ollama.
# Install Ollama, run `ollama pull llama3.2:3b`, then set AI_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Optional free local transcription via a Whisper CLI you install separately.
# Example command shape depends on your local tool.
LOCAL_WHISPER_COMMAND=
LOCAL_WHISPER_ARGS=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase / Prisma
DATABASE_URL=
DIRECT_URL=

# UploadThing
UPLOADTHING_TOKEN=

# MCP
MCP_SERVER_COMMAND=npm
MCP_SERVER_ARGS=run,mcp:dev
