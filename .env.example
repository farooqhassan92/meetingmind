# AI providers
# Local development can use Ollama, local Whisper, and Ollama embeddings.
# Production on Vercel should use Groq for AI/transcription and Gemini for embeddings.
AI_PROVIDER=ollama
TRANSCRIPTION_PROVIDER=local
EMBEDDING_PROVIDER=ollama

# Optional free local LLM via Ollama.
# Install Ollama, run `ollama pull llama3.2:3b`, then set AI_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text

# Optional free local transcription via a Whisper CLI you install separately.
# Example command shape depends on your local tool.
LOCAL_WHISPER_COMMAND=
LOCAL_WHISPER_ARGS=

# Optional hosted free-tier production providers.
# Set AI_PROVIDER=groq, TRANSCRIPTION_PROVIDER=groq, and EMBEDDING_PROVIDER=gemini in production.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
GEMINI_API_KEY=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase / Prisma
DATABASE_URL=
DIRECT_URL=

# UploadThing
UPLOADTHING_TOKEN=

# Email invitations
RESEND_API_KEY="re_7o7uBZqG_F2ZfRFLdgT2TXVxL6yr6RMPw"
INVITE_FROM_EMAIL="MeetingMind <onboarding@resend.dev>"
APP_URL=http://localhost:3000

# MCP
MCP_SERVER_COMMAND=npm
MCP_SERVER_ARGS=run,mcp:dev
